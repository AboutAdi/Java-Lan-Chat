<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.voibiz.lanchat.desktop.controller.MainController">
    <left>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label text="Online Peers" />
            <ListView fx:id="peerList" VBox.vgrow="ALWAYS" />
        </VBox>
    </left>
    <center>
        <BorderPane>
            <center>
                <ScrollPane fitToWidth="true" vbarPolicy="ALWAYS">
                    <content>
                        <VBox fx:id="chatArea" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
            <bottom>
                <HBox spacing="10.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <TextField fx:id="messageField" HBox.hgrow="ALWAYS" />
                    <Button fx:id="sendButton" text="Send" onAction="#onSend" defaultButton="true" />
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
