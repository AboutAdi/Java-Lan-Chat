<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.voibiz.lanchat.desktop.controller.MainController">
    <!-- Sidebar -->
    <left>
        <VBox prefWidth="300.0" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" styleClass="sidebar-header">
                <Label text="Chats" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111b21;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                <Button fx:id="clearDataButton" text="🗑" onAction="#onClearData" style="-fx-background-color: transparent; -fx-font-size: 18px; -fx-cursor: hand; -fx-text-fill: #e53935;" />
                <Button fx:id="refreshButton" text="⟳" onAction="#onRefresh" style="-fx-background-color: transparent; -fx-font-size: 18px; -fx-cursor: hand;" />
            </HBox>
            <ListView fx:id="peerList" VBox.vgrow="ALWAYS" styleClass="list-view" />
        </VBox>
    </left>
    
    <!-- Chat Area -->
    <center>
        <BorderPane styleClass="chat-pane">
            <!-- Top Header -->
            <top>
                <HBox alignment="CENTER_LEFT" styleClass="chat-header">
                    <VBox>
                        <Label fx:id="chatHeaderName" text="Select a chat" styleClass="chat-header-name" />
                        <Label fx:id="chatHeaderStatus" text="" styleClass="chat-header-status" />
                    </VBox>
                </HBox>
            </top>
            
            <!-- Messages -->
            <center>
                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" vbarPolicy="AS_NEEDED" styleClass="chat-scroll-pane">
                    <content>
                        <VBox fx:id="chatArea" spacing="2.0">
                            <padding>
                                <Insets bottom="20.0" left="50.0" right="50.0" top="20.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
            
            <!-- Input Area -->
            <bottom>
                <HBox spacing="10.0" styleClass="input-area" alignment="CENTER">
                    <TextField fx:id="messageField" promptText="Type a message" HBox.hgrow="ALWAYS" styleClass="input-field" />
                    <Button fx:id="sendButton" text="➤" onAction="#onSend" defaultButton="true" styleClass="send-button" />
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
