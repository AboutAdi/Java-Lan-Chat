<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.StackPane?>

<VBox alignment="CENTER" spacing="0.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.voibiz.lanchat.desktop.controller.LoginController" styleClass="login-root" stylesheets="@../css/styles.css">
    
    <VBox alignment="CENTER" styleClass="login-card" maxWidth="400" spacing="25">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <StackPane>
            <Circle radius="40" fill="#00a884" />
            <Label text="LAN" textFill="white" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        </StackPane>
        
        <VBox alignment="CENTER" spacing="5">
            <Label text="Welcome to LAN Chat" styleClass="login-title" />
            <Label text="Connect with peers on your local network" styleClass="login-subtitle" />
        </VBox>

        <VBox spacing="10" maxWidth="300">
            <Label text="Your Display Name" styleClass="login-label" />
            <TextField fx:id="usernameField" promptText="e.g. John Doe" styleClass="login-input" />
        </VBox>

        <Button fx:id="joinButton" text="Join Chat" defaultButton="true" onAction="#onJoin" styleClass="login-button" maxWidth="300" />
    </VBox>

</VBox>
